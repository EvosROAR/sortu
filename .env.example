# Firebase — copy to `.env` lalu isi dari Firebase Console
# Project Settings → Your apps → Web app

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Midtrans Sandbox
EXPO_PUBLIC_MIDTRANS_CLIENT_KEY=
# URL Vercel setelah deploy API (tanpa slash di akhir)
# EXPO_PUBLIC_MIDTRANS_API_URL=https://sortu-api.vercel.app
# EXPO_PUBLIC_MIDTRANS_PRODUCTION=false

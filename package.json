{
  "name": "sortu",
  "version": "0.1.0",
  "private": true,
  "description": "Sortu — envelope budgeting app. Sort your money into pockets for bills & subscriptions.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "deploy:web": "npm run build:web && firebase deploy --only hosting:sortu",
    "build:android": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.0",
    "@expo-google-fonts/fraunces": "^0.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.2",
    "expo-application": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-intent-launcher": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-sharing": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "firebase": "^12.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  }
}
